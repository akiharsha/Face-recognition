# Environment Variables Template
# =============================

# Flask Configuration
FLASK_ENV=production
SECRET_KEY=your-secret-key-here-change-this-to-something-secure

# Python Configuration  
PYTHON_VERSION=3.9

# Model Configuration
DEVICE=cpu
SIMILARITY_THRESHOLD=0.6

# File Upload Configuration
MAX_CONTENT_LENGTH=16777216
UPLOAD_FOLDER=dataset

# Vercel Specific Configuration
VERCEL_PLATFORM=serverless
VERCEL_TIMEOUT=10
VERCEL_MEMORY=1024

# Security Notes:
# 1. Change SECRET_KEY to a strong, random value
# 2. Use python -c "import secrets; print(secrets.token_urlsafe(32))" to generate
# 3. Keep this file secret and don't commit to version control
